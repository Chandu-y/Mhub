# ==================================================
# MHub Production Environment Configuration
# ==================================================
# Copy this to .env and configure for your environment
# ==================================================

# Server
NODE_ENV=production
PORT=5000

# Database - Primary (Writes)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mhub
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_MAX=20

# Database - Read Replicas (comma-separated)
# Leave empty if no replicas configured
DB_REPLICA_HOSTS=
DB_REPLICA_PORT=5432
DB_REPLICA_POOL_MAX=10

# Redis (Distributed Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# API URLs
VITE_API_BASE_URL=https://api.mhub.com

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Push Notifications (Firebase)
FCM_SERVER_KEY=
