{
  "name": "mhub-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/dev.js",
    "doctor": "node scripts/doctor.js",
    "continuous:run": "node scripts/continuous-improvement.js",
    "continuous:run:quick": "node scripts/continuous-improvement.js --mode=quick",
    "continuous:run:strict": "node scripts/continuous-improvement.js --mode=strict --fail-fast=true",
    "continuous:watch": "node scripts/continuous-improvement.js --mode=standard --watch=true --interval-seconds=300",
    "continuous:watch:strict": "node scripts/continuous-improvement.js --mode=strict --watch=true --interval-seconds=300 --fail-fast=true",
    "continuous:watch:strict:nonstop": "node scripts/continuous-improvement.js --mode=strict --watch=true --interval-seconds=300 --fail-fast=false",
    "implementation:safe": "node scripts/safe-e2e-implementation.js --mode=standard",
    "implementation:safe:dry-run": "node scripts/safe-e2e-implementation.js --mode=standard --dry-run=true",
    "implementation:safe:strict": "node scripts/safe-e2e-implementation.js --mode=strict --fail-fast=true --refresh-backup-evidence=true --enforce-ops-gate=true",
    "implementation:safe:watch": "node scripts/safe-e2e-implementation.js --mode=strict --watch=true --interval-seconds=300 --fail-fast=false --refresh-backup-evidence=true --enforce-ops-gate=true",
    "proactive:test": "node scripts/proactive-check.js",
    "release:gate": "npm run proactive:test && npm run doctor && npm run ops:gate:strict:enforced",
    "check:proactive-workflow-contract": "node scripts/check-proactive-workflow-contract.js",
    "proactive:verify-alert-lifecycle": "node scripts/verify-proactive-alert-lifecycle.js",
    "proactive:verify-alert-lifecycle:auto-token": "node scripts/run-proactive-alert-lifecycle.js",
    "check:testcase-catalog": "node scripts/check-testcase-catalog.js",
    "check:backup-toolchain": "node scripts/check-backup-toolchain.js",
    "audit:worktree": "node scripts/worktree-risk-audit.js",
    "cleanup:checklist": "node scripts/release-cleanup-checklist.js",
    "backup:evidence:refresh": "node scripts/refresh-backup-evidence.js",
    "backup:evidence:refresh:force": "node scripts/refresh-backup-evidence.js --force=true",
    "ops:gate": "node scripts/operations-gate.js",
    "ops:gate:strict": "node scripts/operations-gate.js --strict=true",
    "ops:gate:strict:enforced": "node scripts/operations-gate.js --strict=true --enforce-failover=true --enforce-backup=true",
    "footprint:report": "node scripts/footprint-report.js",
    "footprint:guard": "node scripts/guard-footprint.js",
    "footprint:guard:strict": "node scripts/guard-footprint.js --strict-tracked",
    "footprint:guard:tracked-deps": "node scripts/guard-tracked-deps.js",
    "lines:report": "node scripts/line-budget.js --mode=report --threshold=50000",
    "lines:guard": "node scripts/line-budget.js --mode=guard --threshold=50000",
    "validate:locales": "node scripts/validate-locales.js",
    "optimize:locales": "node scripts/optimize-locales.js",
    "optimize:run": "node scripts/optimize-pipeline.js",
    "optimize:run:aggressive": "node scripts/optimize-pipeline.js --aggressive",
    "optimize:run:aggressive:with-install": "node scripts/optimize-pipeline.js --aggressive --with-install",
    "optimize:footprint": "node scripts/optimize-footprint.js",
    "optimize:footprint:aggressive": "node scripts/optimize-footprint.js --aggressive",
    "optimize:footprint:aggressive:remove-deps": "node scripts/optimize-footprint.js --aggressive --confirm-remove-deps",
    "install:client": "node scripts/safe-install.js client",
    "install:server": "node scripts/safe-install.js server",
    "install:all": "npm run install:client && npm run install:server",
    "install:all:prod": "node scripts/safe-install.js client --prod && node scripts/safe-install.js server --prod",
    "dedupe:client": "npm dedupe --prefix client",
    "dedupe:server": "npm dedupe --prefix server",
    "dedupe:all": "npm run dedupe:client && npm run dedupe:server",
    "install:all:optimized": "npm run install:all && npm run dedupe:all && npm run footprint:report"
  }
}
