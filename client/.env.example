# =============================================
# MHub Client Environment Variables
# Copy this to .env and fill in your values
# =============================================

# API Base URL
# Default local backend runs on :5001 to avoid collisions with other projects.
# Set to empty only if you explicitly want same-origin proxy mode.
VITE_API_BASE_URL=http://localhost:5001
VITE_SOCKET_URL=http://localhost:5001
VITE_ENABLE_ERROR_REPORTING=false
VITE_ENABLE_DEFENSE_DEBUGGER_TRAP=false
VITE_SENTRY_DSN=

# Pusher (Realtime Chat)
# Get from: https://pusher.com
VITE_PUSHER_KEY=your_pusher_key
VITE_PUSHER_CLUSTER=ap2

# reCAPTCHA (Optional)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# VAPID (Push Notifications)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
